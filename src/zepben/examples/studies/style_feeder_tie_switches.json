[
  {
    "id": "feeder-tie-switch-mv-mv",
    "name": "Feeder Tie Switches (MV↔MV)",
    "type": "circle",
    "minzoom": 11,
    "paint": {
      "circle-radius": 9,
      "circle-color": "rgb(49,130,189)",
      "circle-stroke-color": "white",
      "circle-stroke-width": 1.5
    },
    "filter": ["all", ["==", ["get", "type"], "switch"], ["==", ["get", "tie_type"], "mv_mv_tie"]]
  },
  {
    "id": "feeder-tie-switch-label-mv-mv",
    "name": "Feeder Tie Switch Labels (MV↔MV)",
    "type": "symbol",
    "minzoom": 13,
    "layout": {
      "text-field": [
        "concat",
        ["get", "name"],
        " (MV↔MV, containers: ",
        ["to-string", ["get", "container_count"]],
        ")"
      ],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 11
    },
    "paint": {
      "text-color": "black",
      "text-halo-blur": 6,
      "text-halo-width": 4,
      "text-halo-color": "white"
    },
    "filter": ["all", ["==", ["get", "type"], "switch"], ["==", ["get", "tie_type"], "mv_mv_tie"]]
