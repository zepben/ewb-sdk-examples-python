[
  {
    "id": "uc6-neutral-customer",
    "name": "Neutral integrity faults",
    "type": "circle",
    "minzoom": 10,
    "paint": {
      "circle-radius": [
        "interpolate",
        ["linear"],
        ["get", "fault_events"],
        1,
        6,
        6,
        18
      ],
      "circle-color": [
        "match",
        ["get", "feature_kind"],
        "neutral_customer",
        "#de2d26",
        "#de2d26"
      ],
      "circle-opacity": 0.9,
      "circle-stroke-color": "#ffffff",
      "circle-stroke-width": 1.2
    },
    "metadata": {
      "zb:legend": {
        "label": "Neutral integrity fault detection"
      }
    },
    "filter": ["all", ["==", ["get", "use_case"], 6], ["==", ["get", "feature_kind"], "neutral_customer"]]
  },
  {
    "id": "uc6-neutral-label",
    "name": "Neutral fault labels",
    "type": "symbol",
    "minzoom": 15,
    "layout": {
      "text-field": ["get", "fault_label"],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 22,
      "text-allow-overlap": true,
      "text-ignore-placement": true
    },
    "paint": {
      "text-color": "#202020",
      "text-halo-color": "#ffffff",
      "text-halo-width": 2
    },
    "filter": ["all", ["==", ["get", "use_case"], 6], ["==", ["get", "feature_kind"], "neutral_customer"]]
  },
  {
    "id": "uc7-voltage-heatmap",
    "name": "Voltage heatmap",
    "type": "heatmap",
    "maxzoom": 15,
    "paint": {
      "heatmap-weight": [
        "interpolate",
        ["linear"],
        ["get", "voltage_heat_weight"],
        0,
        0,
        1,
        0.8
      ],
      "heatmap-intensity": [
        "interpolate",
        ["linear"],
        ["zoom"],
        6,
        0.08,
        9,
        0.2,
        12,
        0.55,
        14,
        1.0
      ],
      "heatmap-radius": [
        "interpolate",
        ["linear"],
        ["zoom"],
        6,
        12,
        9,
        16,
        12,
        24,
        14,
        32
      ],
      "heatmap-opacity": [
        "interpolate",
        ["linear"],
        ["zoom"],
        6,
        0.36,
        10,
        0.55,
        14,
        0.85
      ],
      "heatmap-color": [
        "interpolate",
        ["linear"],
        ["heatmap-density"],
        0,
        "rgba(33,102,172,0)",
        0.2,
        "rgb(146,197,222)",
        0.4,
        "rgb(209,229,240)",
        0.6,
        "rgb(253,219,199)",
        0.8,
        "rgb(244,165,130)",
        1,
        "rgb(214,96,77)"
      ]
    },
    "metadata": {
      "zb:legend": {
        "label": "Voltage monitoring and reporting"
      }
    },
    "filter": ["all", ["==", ["get", "use_case"], 7], ["==", ["get", "feature_kind"], "voltage_customer"]]
  },
  {
    "id": "uc7-voltage-hotspot",
    "name": "Voltage severe points",
    "type": "circle",
    "minzoom": 11,
    "paint": {
      "circle-radius": 3,
      "circle-color": "#b10026",
      "circle-opacity": 0.45,
      "circle-stroke-width": 0
    },
    "filter": [
      "all",
      ["==", ["get", "use_case"], 7],
      ["==", ["get", "feature_kind"], "voltage_customer"],
      ["==", ["get", "severe"], 1]
    ]
  },
  {
