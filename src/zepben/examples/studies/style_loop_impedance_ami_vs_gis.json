[
  {
    "id": "loop-impedance-error-circle",
    "name": "Loop Impedance R Error",
    "type": "circle",
    "minzoom": 11,
    "paint": {
      "circle-radius": 10,
      "circle-color": [
        "case",
        ["==", ["get", "r_error"], 0],
        "rgb(160,160,160)",
        ["step", ["get", "r_error"],
          "rgb(0,180,40)", 0.04,
          "rgb(171,221,164)", 0.10,
          "rgb(255,217,47)", 0.22,
          "rgb(253,174,97)", 0.54,
          "rgb(244,109,67)", 0.76,
          "rgb(210,2,29)", 1.14,
          "rgb(126,1,35)"
        ]
      ],
      "circle-opacity": 0.92,
      "circle-stroke-color": "white",
      "circle-stroke-width": 1.2
    },
    "filter": ["==", ["get", "type"], "usage_point"]
  },
  {
    "id": "loop-impedance-error-label",
    "name": "Loop Impedance R Error Label",
    "type": "symbol",
    "minzoom": 13,
    "layout": {
      "text-field": ["get", "r_error_label"],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 11,
      "text-offset": [0, 1.2]
    },
    "paint": {
      "text-color": "black",
      "text-halo-blur": 4,
      "text-halo-width": 2,
      "text-halo-color": "white"
    },
    "filter": ["==", ["get", "type"], "usage_point"]
  },
