[
  {
    "id": "hc-peak-import-line",
    "name": "Peak Import Lines",
    "type": "line",
    "paint": {
      "line-width": 4.6,
      "line-opacity": 0.92,
      "line-color": [
        "match",
        ["get", "bucket"],
        0, "#2c7bb6",
        1, "#00a6ca",
        2, "#fdae61",
        3, "#f46d43",
        4, "#d73027",
        "#8f8f8f"
      ]
    },
    "metadata": {
      "zb:legend": {
        "label": "Peak Import",
        "states": [
          { "label": "Very Low (#2c7bb6)", "properties": { "bucket": 0 } },
          { "label": "Low (#00a6ca)", "properties": { "bucket": 1 } },
          { "label": "Medium (#fdae61)", "properties": { "bucket": 2 } },
          { "label": "High (#f46d43)", "properties": { "bucket": 3 } },
          { "label": "Very High (#d73027)", "properties": { "bucket": 4 } }
        ]
      }
    },
    "filter": ["all", ["==", ["get", "metric_key"], "peak_import"], ["==", ["get", "geom_kind"], "line"]]
  },
  {
    "id": "hc-peak-import-label",
    "name": "Peak Import Labels",
    "type": "symbol",
    "minzoom": 13,
    "layout": {
      "symbol-placement": "line-center",
      "text-field": ["get", "value_label"],
      "text-size": 10
    },
    "paint": {
      "text-color": "#1f2a44",
      "text-halo-color": "#ffffff",
      "text-halo-width": 1.2
    },
    "filter": ["all", ["==", ["get", "metric_key"], "peak_import"], ["==", ["get", "geom_kind"], "line"]]
  },
  {
    "id": "hc-peak-import-point",
