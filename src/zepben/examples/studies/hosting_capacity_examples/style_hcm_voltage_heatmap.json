        15, 6.2
      ],
      "line-opacity": 0.9,
      "line-color": [
        "match",
        ["get", "bucket"],
        0, "#d73027",
        1, "#fdae61",
        2, "#1a9850",
        "#8f8f8f"
      ]
    },
    "metadata": {
      "zb:legend": {
        "label": "V99 Avg Section Voltage (Line-Ground)",
        "states": [
          { "label": "Outside Limit (>235V or <216V) - Red", "properties": { "bucket": 0 } },
          { "label": "Approaching Limit (216-225V) - Orange", "properties": { "bucket": 1 } },
          { "label": "Normal (225-235V) - Green", "properties": { "bucket": 2 } }
        ]
